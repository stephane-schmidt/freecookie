#. Plugin Name of the plugin
#: freecookie.php
msgid "FreeCookie — Cookie Consent RGPD/CNIL"
msgstr ""

#. Plugin URI of the plugin
#: freecookie.php
msgid "https://github.com/stephane-schmidt/freecookie"
msgstr ""

#. Description of the plugin
#: freecookie.php
msgid "Bandeau de consentement cookies 100 % local, conforme RGPD / ePrivacy / CNIL / nLPD. Blocage réel des traceurs avant consentement, journal de preuve dans votre base, Google Consent Mode v2, multilingue automatique. Aucun appel réseau tiers."
msgstr "100% lokale cookiebanner voor toestemming, conform AVG / ePrivacy / CNIL / nLPD. Echte blokkering van trackers vóór toestemming, bewijslogboek in uw database, Google Consent Mode v2, automatisch meertalig. Geen netwerkoproepen naar derden."

#. Author of the plugin
#: freecookie.php
msgid "Stéphane Schmidt"
msgstr ""

